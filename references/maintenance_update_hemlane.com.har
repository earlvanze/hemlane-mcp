            "text": "{\"operationName\":\"OwnerDashboardMaintenanceMaintenanceRequestComments\",\"variables\":{\"maintenanceRequestId\":\"8609a66f-8403-483c-aaef-fecfa199c9bd\"},\"query\":\"query OwnerDashboardMaintenanceMaintenanceRequestComments($maintenanceRequestId: ID!) {\\n  maintenanceRequestComments(maintenanceRequestId: $maintenanceRequestId) {\\n    edges {\\n      cursor\\n      node {\\n        id\\n        body\\n        isHiddenFromTenants\\n        createdAt\\n        createdBy {\\n          id\\n          fullName\\n          isAdmin\\n          vendorProfile {\\n            id\\n            profileImageUrl\\n            __typename\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      startCursor\\n      endCursor\\n      hasPreviousPage\\n      hasNextPage\\n      __typename\\n    }\\n    __typename\\n  }\\n}\\n\"}"
