s {\\n      node {\\n        id\\n        status\\n        taskType\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment NewDashboardOnboardingVerifyBankAccountTasks on Query {\\n  onboardingVerifyBankAccountTasks: tasksByType(taskType: OnboardingVerifyBankAccount, status: $status, isActive: $isActive, first: $first) {\\n    taskType\\n    displayRank\\n    canDefer\\n    canBulkDefer\\n    totalCount\\n    edges {\\n      node {\\n        id\\n        status\\n        taskType\\n        paymentAccount: taskable {\\n          ... on PaymentAccount {\\n            __typename\\n            id\\n            accountName\\n            accountLast4\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment NewDashboardOnboardingUpdateExpiringCreditCardTasks on Query {\\n  onboardingUpdateExpiringCreditCardTasks: tasksByType(taskType: OnboardingUpdateExpiringCreditCard, status: $status, isActive: $isActive, first: $first) {\\n    taskType\\n    displayRank\\n    canDefer\\n    canBulkDefer\\n    totalCount\\n    edges {\\n      node {\\n        id\\n        status\\n        taskType\\n        paymentAccount: taskable {\\n          ... on PaymentAccount {\\n            __typename\\n            id\\n            accountName\\n            accountLast4\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment NewDashboardOnboardingSetupLeasingAgentProfileTasks on Query {\\n  onboardingSetupLeasingAgentProfileTasks: tasksByType(taskType: OnboardingSetupLeasingAgentProfile,