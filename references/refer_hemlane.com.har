            "mimeType": "application/json",
            "text": "{\"operationName\":\"ODDashboardConsolidatedQuery\",\"variables\":{},\"query\":\"query ODDashboardConsolidatedQuery($status: TaskStatus, $isActive: Boolean, $first: Int) {\\n  tenantsDashboardStats {\\n    expiringIn30\\n    expiringIn60\\n    expiringIn90\\n    occupiedUnitCount\\n    totalUnitCount\\n    __typename\\n  }\\n  prospectiveTenantInfo {\\n    id\\n    inquiryLeadsCount\\n    qualificationTenantGroupsCount\\n    moveInTenantGroupsCount\\n    __typename\\n  }\\n  adminUser {\\n    id\\n    __typename\\n  }\\n  currentUser {\\n    id\\n    trialEndDate\\n    isStripeSubscriptionStatusDelinquent\\n    isOnStarterPlan\\n    freePlanModalAcknowledged\\n    metaActiveBillToUnitCount\\n    metaAgentBillToUnitCount\\n    stripeSubscriptionInvoiceStatusStr\\n    stripeSubscriptionStatus\\n    shouldTakeCareOfSubscriptionPayments\\n    myProperties(isDeleted: false, isBillTo: true) {\\n      data {\\n        id\\n        addressLat\\n        addressLng\\n        packageType\\n        billToUser {\\n          id\\n          isOnStarterPlan\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    currentUserInfo {\\n      id\\n      viewAsUsers {\\n        id\\n        fullName\\n        email\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n  maintenanceServiceRequestCategories(nonDeprecated: true) {\\n    value\\n    label\\n    __typename\\n  }\\n  paginatedMaintenanceRequests(isOpen: true, pagination: {page: 1, limit: 2}, updatedAtOrder: Descending) {\\n    data {\\n      id\\n      property {\\n        id\\n        nickname\\n        __typename\\n      }\\n      category\\n      title\\n      createdAt\\n      updatedAt\\n      coordinatedBy {\\n        firstName\\n        __typename\\n      }\\n      maintenanceRequestComments {\\n        totalCount\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      totalCount\\n      __typename\\n    }\\n    __typename\\n  }\\n  ...NewDashboardOnboardingVerifyIdentityTasks\\n  ...NewDashboardOnboardingVerifyCredentialsTasks\\n  ...NewDashboardPropertySetupAcceptPropertyMemberInviteTasks\\n  ...NewDashboardOnboardingStartSubscriptionTasks\\n  ...NewDashboardOnboardingUnpaidSubscriptionTasks\\n  ...NewDashboardOnboardingReactivateSubscriptionTasks\\n  ...NewDashboardOnboardingVerifyPhoneNumberTasks\\n  ...NewDashboardOnboardingConfirmOwnerAddressTasks\\n  ...NewDashboardOnboardingSetupBankAccountTasks\\n  ...NewDashboardOnboardingVerifyBankAccountTasks\\n  ...NewDashboardOnboardingUpdateExpiringCreditCardTasks\\n  ...NewDashboardOnboardingSetupLeasingAgentProfileTasks\\n  ...NewDashboardOnboardingSetupOwnerTypesTasks\\n  ...NewDashboardOnboardingBankSyncConnectTasks\\n}\\n\\nfragment NewDashboardOnboardingVerifyIdentityTasks on Query {\\n  onboardingVerifyIdentityTasks: tasksByType(taskType: OnboardingVerifyIdentity, status: $status, isActive: $isActive, first: $first) {\\n    taskType\\n    displayRank\\n    canDefer\\n    canBulkDefer\\n    totalCount\\n    edges {\\n      node {\\n        id\\n        status\\n        taskType\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment NewDashboardOnboardingVerifyCredentialsTasks on Query {\\n  onboardingVerifyCredentialsTasks: tasksByType(taskType: OnboardingVerifyCredentials, status: $status, isActive: $isActive, first: $first) {\\n    taskType\\n    displayRank\\n    canDefer\\n    canBulkDefer\\n    totalCount\\n    edges {\\n      node {\\n        id\\n        status\\n        taskType\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment NewDashboardPropertySetupAcceptPropertyMemberInviteTasks on Query {\\n  propertySetupAcceptPropertyMemberInviteTasks: tasksByType(taskType: PropertySetupAcceptPropertyMemberInvite, status: $status, isActive: $isActive, first: $first) {\\n    taskType\\n    displayRank\\n    canDefer\\n    canBulkDefer\\n    totalCount\\n    edges {\\n      node {\\n        id\\n        status\\n        taskType\\n        propertyMember: taskable {\\n          ... on PropertyMember {\\n            __typename\\n            id\\n            createdBy {\\n              id\\n              fullName\\n              __typename\\n            }\\n            property {\\n              id\\n              addressStreet\\n              __typename\\n            }\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment NewDashboardOnboardingStartSubscriptionTasks on Query {\\n  onboardingStartSubscriptionTasks: tasksByType(taskType: OnboardingStartSubscription, status: $status, isActive: $isActive, first: $first) {\\n    taskType\\n    displayRank\\n    canDefer\\n    canBulkDefer\\n    totalCount\\n    edges {\\n      node {\\n        id\\n        status\\n        taskType\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment NewDashboardOnboardingUnpaidSubscriptionTasks on Query {\\n  onboardingUnpaidSubscriptionTasks: tasksByType(taskType: OnboardingUnpaidSubscription, status: $status, isActive: $isActive, first: $first) {\\n    taskType\\n    displayRank\\n    canDefer\\n    canBulkDefer\\n    totalCount\\n    edges {\\n      node {\\n        id\\n        status\\n        taskType\\n        __typename\\n      }\\n      __typename\\n    }\\n    pageInfo {\\n      hasNextPage\\n      endCursor\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\